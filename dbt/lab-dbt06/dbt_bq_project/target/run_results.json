\n\nranked_books AS (\n    SELECT\n        *,\n        RANK() OVER (PARTITION BY sales_month ORDER BY total_units_sold DESC) as monthly_rank\n    FROM monthly_sales\n)\n\nSELECT * FROM ranked_books\nORDER BY sales_month DESC, monthly_rank ASC", "relation_name": "`uam-proj`.`bookstore_semantic`.`report_monthly_book_ranking`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-26T09:46:16.520772Z", "completed_at": "2026-04-26T09:46:16.536578Z"}, {"name": "execute", "started_at": "2026-04-26T09:46:16.546891Z", "completed_at": "2026-04-26T09:46:19.689875Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 3.19006085395813, "adapter_response": {"_message": "CREATE TABLE (10.0 rows, 246.8 KiB processed)", "code": "CREATE TABLE", "rows_affected": 10, "bytes_processed": 252771, "bytes_billed": 20971520, "location": "EU", "project_id": "uam-proj", "job_id": "4efb31b9-b098-4698-a632-f2c823f1637f", "slot_ms": 509}, "message": "CREATE TABLE (10.0 rows, 246.8 KiB processed)", "failures": null, "unique_id": "model.dbt_bq_project.report_top_10_authors", "compiled": true, "compiled_code": "-- models/semantic/report_top_10_authors.sql\n\n\nSELECT\n    a.author_name,\n    SUM(f.total_item_price) as total_revenue,\n    SUM(f.quantity) as total_units_sold,\n    COUNT(DISTINCT f.transaction_id) as total_transactions\nFROM `uam-proj`.`bookstore_dwh`.`fct_transactions` f\nJOIN `uam-proj`.`bookstore_dwh`.`dim_authors` a ON f.author_id = a.author_id\nGROUP BY 1\nORDER BY total_revenue DESC\nLIMIT 10", "relation_name": "`uam-proj`.`bookstore_semantic`.`report_top_10_authors`", "batch_results": null}], "elapsed_time": 19.450489044189453, "args": {"skip_nodes_if_on_run_start_fails": false, "invocation_command": "dbt run", "log_format": "default", "strict_mode": false, "vars": {}, "upload_to_artifacts_ingest_api": false, "state_modified_compare_vars": false, "defer": false, "send_anonymous_usage_stats": true, "log_level_file": "debug", "favo