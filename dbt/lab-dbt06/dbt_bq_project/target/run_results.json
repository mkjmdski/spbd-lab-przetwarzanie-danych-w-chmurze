* FROM `uam-proj`.`bookstore_stg`.`stg_transactions`\n),\ncustomers AS (\n    SELECT * FROM `uam-proj`.`bookstore_stg`.`stg_customers`\n),\nbooks AS (\n    SELECT * FROM `uam-proj`.`bookstore_stg`.`stg_books`\n),\n\n-- Krok 1: Rozp\u0142aszczamy pozycje i \u0142\u0105czymy z informacjami o ksi\u0105\u017ckach\n-- U\u017cywamy COALESCE i SAFE_CAST, aby zamieni\u0107 b\u0142\u0119dy na nasz klucz techniczny -1\nflattened_items AS (\n    SELECT\n        t.transaction_id,\n        STRUCT(\n            COALESCE(SAFE_CAST(i.book_id AS INT64), -1) as book_id,\n            b.title as book_title,\n            b.author as book_author,\n            b.publisher as book_publisher,\n            b.category as book_category,\n            i.unit_price,\n            i.quantity\n        ) as item_enriched\n    FROM transactions t\n    CROSS JOIN UNNEST(t.items) i\n    LEFT JOIN books b ON COALESCE(SAFE_CAST(i.book_id AS INT64), -1) = b.book_id\n),\n\n-- Krok 2: Ponownie agregujemy wzbogacone pozycje do tablicy\naggregated_items AS (\n    SELECT\n        transaction_id,\n        ARRAY_AGG(item_enriched) as items\n    FROM flattened_items\n    GROUP BY transaction_id\n)\n\n-- Krok 3: \u0141\u0105czymy wszystko w finalny model\nSELECT\n    t.* EXCEPT(items),\n    ai.items,\n    c.first_name,\n    c.last_name,\n    c.email,\n    c.registration_date\nFROM transactions t\nLEFT JOIN aggregated_items ai ON t.transaction_id = ai.transaction_id\nLEFT JOIN customers c ON t.customer_id = c.customer_id", "relation_name": "`uam-proj`.`bookstore_int`.`prep_transactions_enriched`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-26T09:46:08.605751Z", "completed_at": "2026-04-26T09:46:08.616084Z"}, {"name": "execute", "started_at": "2026-04-26T09:46:08.617268Z", "completed_at": "2026-04-26T09:46:11.707184Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 3.1123604774475098, "adapter_response": {"_message": "CREATE TABLE (505.0 rows, 184.9 KiB 